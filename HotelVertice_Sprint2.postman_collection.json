                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.data && jsonData.data.session) {",
                                    "    pm.environment.set(\"auth_token\", jsonData.data.session.access_token);",
                                    "}"
                                ],
                                "type": "text/javascript"
